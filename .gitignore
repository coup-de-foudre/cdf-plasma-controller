.idea
.DS_Store
\#*\#
*~

# Raw IanniX captures used to derive scores/*.csv. Regenerate with
# extras/iannix/osc_sink.py if you need them.
scores/capture/
# Player-output captures used to verify the score player end-to-end.
# Regenerable via extras/iannix/capture_player.sh.
scores/capture_player/
# Localhost-rewritten copy of the IanniX score; regenerable via
# extras/iannix/rewrite_for_localhost.py.
extras/iannix/*.localhost.iannix

### Python template
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py

